{
  "name": "disaster-alert-server",
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "CLIENT_URL": "@client_url",
    "OPENWEATHER_API_KEY": "@openweather_api_key",
    "EMAIL_USER": "@email_user",
    "EMAIL_PASS": "@email_pass",
    "DEMO_MODE": "false",
    "NODE_ENV": "production"
  }
}
