# ═══════════════════════════════════════════════════════════
# 🛡️ DISASTER ALERT SYSTEM - SERVER ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════

# ─── DATABASE ──────────────────────────────────────────
# MongoDB Atlas Connection String
# 1. Go to https://www.mongodb.com/atlas
# 2. Create/select a cluster
# 3. Click "Connect" → "Connect your application"
# 4. Copy the connection string and replace <username> and <password>
# 5. Add /disasterDB before the ? for better organization
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/disasterDB?retryWrites=true&w=majority

# ─── AUTHENTICATION ────────────────────────────────────
# JWT Secret - Generate a strong random string (min 32 chars)
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── SERVER ────────────────────────────────────────────
# Server port (Vercel uses PORT env var)
PORT=5000

# Node environment
NODE_ENV=production

# ─── FRONTEND URL ─────────────────────────────────────
# For CORS and frontend communication
# Local dev: http://localhost:5173
# Production: https://your-frontend-domain.vercel.app
CLIENT_URL=http://localhost:5173,https://your-frontend-domain.vercel.app

# ─── WEATHER API ──────────────────────────────────────
# OpenWeatherMap API Key (optional)
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── EMAIL SERVICE ─────────────────────────────────────
# For Gmail SMTP alerts
# 1. Enable 2FA on Gmail
# 2. Generate app-specific password: https://myaccount.google.com/apppasswords
# 3. Use the generated password below
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# ─── DEMO MODE ───────────────────────────────────────
# Set to false to use real weather data
# Set to true to use mock/demo data
DEMO_MODE=false
